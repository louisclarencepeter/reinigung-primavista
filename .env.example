# Local development with `netlify dev` — copy to .env (never commit .env).
# In production these are set in the Netlify site's environment variables.

# MongoDB connection string (e.g. a free MongoDB Atlas cluster)
MONGODB_URI=

# Secret for reading stored inquiries via GET /api/contact
# (generate one with: openssl rand -hex 32)
ADMIN_TOKEN=

# Key for hashing client IPs in the contact-form rate limiter, so the stored
# hashes can't be brute-forced back to addresses
# (generate one with: openssl rand -hex 32)
IP_HASH_SECRET=
