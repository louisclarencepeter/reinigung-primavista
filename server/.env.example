# Optional: MongoDB connection string (Atlas or local mongod).
# If unset, the dev server uses an in-memory MongoDB (data is not persisted).
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/primavista
PORT=5001

